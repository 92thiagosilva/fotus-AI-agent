# ==========================================
# Supabase
# ==========================================
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...sua_anon_key...

# Chave service_role — NUNCA exponha no cliente
# Usada apenas no servidor para inserir chunks (bypass RLS)
SUPABASE_SERVICE_ROLE_KEY=eyJ...sua_service_role_key...

# ==========================================
# Google Gemini
# ==========================================
GOOGLE_GEMINI_API_KEY=AIza...sua_api_key...

# ==========================================
# App
# ==========================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
